@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8">
            <h1 class="text-light mb-4">@ViewData["Title"]</h1>
            
            <div class="card general-block">
                <div class="card-body p-4">
                    <h4 class="card-title text-light mb-3">Your Privacy Matters</h4>
                    
                    <h6 class="text-light mt-4">Information We Collect</h6>
                    <p class="text-light">When you create an account or use our service, we collect information such as your username and password to provide you with access to our platform.</p>
                    
                    <h6 class="text-light mt-4">How We Use Your Information</h6>
                    <p class="text-light">We use your information to operate and improve our service, authenticate your account, and provide customer support.</p>
                    
                    <h6 class="text-light mt-4">Data Security</h6>
                    <p class="text-light">We take reasonable measures to protect your information from unauthorized access and use.</p>
                    
                    <h6 class="text-light mt-4">Contact Us</h6>
                    <p class="text-light">If you have any questions about this privacy policy, please contact us.</p>
                    
                    <hr class="my-4">
                    <p class="text-muted small">Last updated: March 2026</p>
                </div>
            </div>
        </div>
    </div>
</div>
