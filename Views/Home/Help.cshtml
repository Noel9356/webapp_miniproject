@{
    ViewData["Title"] = "Help";
}

<div class="help-page">

    <!-- Header -->
    <div class="help-header text-center">
        <h1>Help Center</h1>
        <p>Learn how to use our website to find players and build your gaming team.</p>
    </div>

    <!-- How it works -->
    <div class="container mb-5">

        <h2 class="section-title mb-4">How It Works</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card help-card h-100 text-center">
                    <div class="card-body">
                        <h4>🎮 Choose Game</h4>
                        <p>Select the game you want to play from the home page.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card help-card h-100 text-center">
                    <div class="card-body">
                        <h4>👥 Find Players</h4>
                        <p>Browse available groups created by other players.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card help-card h-100 text-center">
                    <div class="card-body">
                        <h4>🚀 Join or Create</h4>
                        <p>Join an existing group or create your own team.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- How to find players -->
    <div class="container mb-5">

        <h2 class="section-title mb-3">How to Find Players</h2>

        <ol class="help-list">
            <li>Go to the Home page.</li>
            <li>Select the game you want to play.</li>
            <li>Browse available groups.</li>
            <li>Click a group to view details and join.</li>
        </ol>

    </div>

    <!-- How to create group -->
    <div class="container mb-5">

        <h2 class="section-title mb-3">How to Create a Group</h2>

        <ol class="help-list">
            <li>Login to your account.</li>
            <li>Click the <strong>Create</strong> button in the navigation bar.</li>
            <li>Select the game.</li>
            <li>Add group details and description.</li>
            <li>Publish your group and wait for players to join.</li>
        </ol>

    </div>

    <!-- FAQ -->
    <div class="container mb-5">

        <h2 class="section-title mb-4">Frequently Asked Questions</h2>

        <div class="accordion" id="faq">

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#q1">
                        Do I need an account to join a group?
                    </button>
                </h2>
                <div id="q1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        Yes. You need to login before joining or creating groups.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q2">
                        Is the website free?
                    </button>
                </h2>
                <div id="q2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Yes. The platform is completely free for all users.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q3">
                        Can I create multiple groups?
                    </button>
                </h2>
                <div id="q3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Yes, but we recommend managing one active group at a time.
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>