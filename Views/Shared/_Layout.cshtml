<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - webapp_miniproject</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/webapp_miniproject.styles.css" asp-append-version="true" />
</head>

<body class="app-shell">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom fixed-top rgb-line-nav" id="mainNav">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">เล่น(เก)มป่ะ</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="privacy">Help</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="GameGroup" asp-action="Index">Find Group</a>
                        </li>
                    </ul>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="nav-actions d-flex align-items-center gap-2 flex-wrap justify-content-end">
                            <a asp-controller="Account" asp-action="Profile" class="btn btn-sm btn-secondary profile-nav-btn">
                                <span class="profile-dot"></span>
                                @(User.Identity?.Name ?? "Profile")
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="nav-actions d-flex gap-2 flex-wrap justify-content-end">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-light">Sign in</a>
                            <a asp-controller="Account" asp-action="SignUp" class="btn btn-sm btn-primary">Sign up</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="py-3">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
