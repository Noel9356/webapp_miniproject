@model IEnumerable<GameInfo>

@{
    var visibleGames = Model.Where(g => g.GameGroupInfos.Any()).ToList();
}

@if (!visibleGames.Any())
{
    <div class="card general-block rgb-frame p-4">
        <h5 class="text-light mb-2">No groups found</h5>
        <p class="text-muted mb-0">Try another search keyword or change your game filter.</p>
    </div>
}

@foreach (var gameInfo in visibleGames)
{
    <section class="group-section mb-4">
        <div class="group-section-head">
            <h3>@gameInfo.Name</h3>
            <button type="button" class="see-all-btn" data-see-all-game="@gameInfo.Id">See all</button>
        </div>

        <div class="group-scroll-row">
            @foreach (var gameGroup in gameInfo.GameGroupInfos.Take(12))
            {
                <article class="group-card rgb-frame">
                    @if (!string.IsNullOrEmpty(gameGroup.ImageUrl))
                    {
                        <img src="@gameGroup.ImageUrl" class="group-card-image" alt="@gameGroup.Title" loading="lazy" />
                    }
                    else
                    {
                        <div class="group-card-fallback">@gameInfo.Name</div>
                    }

                    <div class="group-card-body">
                        <div class="group-meta-row mb-2">
                            @if (!string.IsNullOrWhiteSpace(gameGroup.QueueType))
                            {
                                <span class="queue-badge @(gameGroup.QueueType == "Competitive" ? "badge-competitive" : "badge-casual")">@gameGroup.QueueType</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(gameGroup.RankTier))
                            {
                                <span class="rank-badge">@gameGroup.RankTier</span>
                            }
                        </div>
                        <div class="group-meta-row mb-2">
                            <span class="member-badge">@gameGroup.CurrentMemberCount/@gameGroup.MaxMembers players</span>
                            <span class="status-badge status-@gameGroup.EffectiveStatus.ToLowerInvariant()">@gameGroup.EffectiveStatus</span>
                        </div>
                        <h5 class="group-card-title">
                            <a asp-controller="GameGroup" asp-action="Details" asp-route-id="@gameGroup.Id">@gameGroup.Title</a>
                        </h5>
                        <p class="group-card-desc">@gameGroup.Description</p>
                    </div>
                </article>
            }
        </div>
    </section>
}
