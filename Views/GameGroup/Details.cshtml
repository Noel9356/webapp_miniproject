@model GameGroupInfo

@{
    ViewData["Title"] = Model.Title;
    var isOwner = (bool)(ViewBag.IsOwner ?? false);
    var memberCount = (int)(ViewBag.MemberCount ?? 0);
    var pendingCount = (int)(ViewBag.PendingCount ?? 0);
    var members = ViewBag.Members as List<webapp_miniproject.Models.UserInfo> ?? new();
    var myRequest = ViewBag.MyRequest as webapp_miniproject.Models.GroupJoinRequestInfo;
    var pendingRequests = ViewBag.PendingRequests as List<(webapp_miniproject.Models.GroupJoinRequestInfo Request, string Username)> ?? new();
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var isApproved = string.Equals(myRequest?.Status, "Approved", StringComparison.OrdinalIgnoreCase);
    var isPending = string.Equals(myRequest?.Status, "Pending", StringComparison.OrdinalIgnoreCase);
    var canRequestAgain = myRequest?.Status is "Rejected" or "Canceled" or "Left";
    @* var pendingRequests = ViewBag.PendingJoinRequests as List<webapp_miniproject.Models.GroupJoinRequestInfo> ?? new(); *@
    @* var currentUserJoinStatus = ViewBag.CurrentUserJoinStatus as string; *@
}

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5 mb-3">
            <div class="card rounded-3 general-block">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" />
                }
                <div class="card-body d-flex flex-column">
                    @if (Model.Game is not null)
                    {
                        <div class="mb-1 small text-muted">@Model.Game.Name</div>
                    }
                    <h1 class="h3 mt-2 mb-3 text-light">@Model.Title</h1>
                    <div class="group-meta-row mb-3">
                        <span class="queue-badge @(Model.QueueType == "Competitive" ? "badge-competitive" : "badge-casual")">@Model.QueueType</span>
                        @if (!string.IsNullOrWhiteSpace(Model.RankTier))
                        {
                            <span class="rank-badge">@Model.RankTier</span>
                        }
                        <span class="member-badge">@(memberCount + 1)/@Model.MaxMembers players</span>
                        <span class="status-badge status-@Model.EffectiveStatus.ToLowerInvariant()">@Model.EffectiveStatus</span>
                    </div>

                    @if (TempData["Message"] is string msg)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                            @msg
                            <button type="button" class="btn-close" onclick="this.closest('.alert').remove()">Dismiss</button>
                        </div>
                    }
                    @if (TempData["Error"] is string err)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                            @err
                            <button type="button" class="btn-close" onclick="this.closest('.alert').remove()">Dismiss</button>
                        </div>
                    }

                    <p class="text-light">@Model.Description</p>

                    <div class="small text-muted mb-3">
                        Created @Model.CreatedAt.ToString("MMM d, yyyy") • @pendingCount pending request(s)
                    </div>

                    <!-- Non-owners: Join / status buttons -->
                    @if (isLoggedIn && !isOwner)
                    {
                        if (isApproved)
                        {
                            <div class="alert mb-3">You are already a member of this group.</div>
                            <form asp-action="Leave" asp-route-id="@Model.Id" method="post" class="mb-2"
                                onsubmit="return confirm('Leave this group?');">
                                <button type="submit" class="btn btn-sm btn-danger w-100">Leave Group</button>
                            </form>
                        }
                        else if (isPending)
                        {
                            <button class="btn btn-sm btn-secondary w-50" disabled>Request Pending</button>
                            <form asp-action="CancelRequest" asp-route-id="@Model.Id" method="post" class="w-50">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Cancel</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="RequestJoin" asp-route-id="@Model.Id" method="post" class="mb-3">
                                <button type="submit" class="btn btn-primary w-100">
                                    @(canRequestAgain ? "Apply Again" : "Apply to Join")
                                </button>
                            </form>
                        }
                    }
                    else if (!isLoggedIn)
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("Details", "GameGroup", new { id = Model.Id })" class="btn btn-secondary w-100 mb-3">Sign in to apply</a>
                    }

                    <!-- Owner controls -->
                    @if (isOwner)
                    {
                        <div class="d-flex gap-2 mt-auto pt-3 border-top border-secondary flex-wrap">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light">Edit</a>
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                                onsubmit="return confirm('Delete this group?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete Group</button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <!-- Members list -->
            @if (members.Any())
            {
                <div class="card rounded-3 general-block mt-3">
                    <div class="card-body">
                        <h6 class="text-light mb-3">Members</h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var user in members)
                            {
                                <li class="text-muted small py-1 border-bottom border-secondary">
                                    @user.Username
                                    @if (user.Id == Model.CreatedBy)
                                    {
                                        <span class="badge bg-secondary ms-1">owner</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

        <div class="col-12 col-md-6 col-lg-5 d-flex flex-column">
            <div class="mb-3">
                <div class="card rounded-3 general-block">
                    <div class="card-header border-bottom border-secondary p-0">
                        <div class="btn-group btn-group-toggle w-100" role="group">
                            <button type="button" class="btn btn-sm btn-secondary text-light flex-grow-1 border-0">
                                <h6 class="text-light mb-0">Details</h6>
                            </button>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column p-3">
                        <p class="text-light">Group status: <strong>@Model.EffectiveStatus</strong></p>
                        <p class="text-light">Capacity: <strong>@(memberCount + 1) / @Model.MaxMembers</strong></p>
                        <p class="text-light mb-0">Queue: <strong>@Model.QueueType</strong></p>
                    </div>
                </div>
            </div>
            <div class="h-100">
                <div class="card rounded-3 p-4 general-block h-100">
                    <!-- Owner controls: Pending requests -->
                    @if (isOwner)
                    {
                        <h4 class="text-light mb-3">Join Requests</h4>
                        @if (pendingRequests.Any())
                        {
                            <div class="request-list">
                                @foreach (var (request, username) in pendingRequests)
                                {
                                    <div class="request-item">
                                        <div>
                                            <div class="request-title">@request.Username</div>
                                            <div class="small text-muted">Requested @request.CreatedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</div>
                                        </div>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <form asp-action="UpdateJoinRequest" asp-route-id="@Model.Id" method="post">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <input type="hidden" name="decision" value="approve" />
                                                <button type="submit" class="btn btn-sm btn-primary">Approve</button>
                                            </form>
                                            <form asp-action="UpdateJoinRequest" asp-route-id="@Model.Id" method="post">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <input type="hidden" name="decision" value="reject" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No pending requests yet.</p>
                        }
                    }
                    else
                    {
                        <h4 class="text-light mb-3">Group Activity</h4>
                        <p class="text-light mb-2">Members: <strong>@Model.CurrentMemberCount</strong></p>
                        <p class="text-light mb-2">Open spots: <strong>@Math.Max(Model.MaxMembers - Model.CurrentMemberCount, 0)</strong></p>
                        <p class="text-muted mb-0">Send a join request if you want to be part of this squad.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
