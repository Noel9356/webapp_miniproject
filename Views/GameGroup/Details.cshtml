@model GameGroupInfo

@{
    ViewData["Title"] = Model.Title;
    var isOwner = (bool)(ViewBag.IsOwner ?? false);
}

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-10 col-md-4 mb-3">
            <div class="card rounded-3 general-block">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" />
                }
                <div class="card-body d-flex flex-column">
                    @if (Model.Game is not null)
                    {
                        <div class="mb-1 small text-muted">@Model.Game.Name</div>
                    }
                    <h1 class="h3 mt-2 mb-3 text-light">@Model.Title</h1>
                    <p class="text-light">@Model.Description</p>

                    <div class="small text-muted mb-3">
                        Created @Model.CreatedAt.ToString("MMM d, yyyy")
                    </div>

                    @if (User.Identity?.IsAuthenticated == true && isOwner)
                    {
                        <div class="container-fluid p-0 mt-auto pt-3 border-top border-secondary">
                            <div class="row row-cols-auto gx-2">
                                <div class="col">
                                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light">Edit</a>
                                </div>
                                <div class="col">
                                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                                        onsubmit="return confirm('Delete this group?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete Group</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col d-flex flex-column">
            <div class="mb-3">
                <div class="card rounded-3 general-block">
                    <div class="w-full flex flex-row border-bottom p-2">
                        <button class="flex flex-col items-center btn">
                            <h4 class="text-light">Skills</h4>
                        </button>
                        <button class="flex flex-col items-center btn">
                            <h4 class="text-light">Moment</h4>
                        </button>
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <p>Test</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="card rounded-3 p-4 general-block">
                    <h4 class="text-light">User Review</h4>
                </div>
            </div>
        </div>
    </div>
</div>
