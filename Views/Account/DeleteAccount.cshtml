@{
    ViewData["Title"] = "Delete Account";
    var error = ViewBag.Error as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-8 col-md-5 col-lg-4">

            <h2 class="text-light text-center mb-2">Delete Account</h2>
            <p class="text-muted text-center mb-4">This is permanent and cannot be undone.</p>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger">@error</div>
            }

            <div class="card general-block border-danger">
                <div class="card-body p-4">
                    <form asp-action="DeleteAccount" method="post">
                        <div class="mb-4">
                            <label class="form-label text-light">
                                Type <strong>DELETE</strong> to confirm
                            </label>
                            <input name="confirm" type="text" class="form-control"
                                   placeholder="DELETE" autocomplete="off" required />
                        </div>

                        <button type="submit" class="btn btn-danger w-100">Permanently Delete Account</button>
                    </form>
                </div>
            </div>

            <p class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="text-muted">Cancel</a>
            </p>

        </div>
    </div>
</div>
